# Arivu Backend Configuration
# Copy to .env and fill in values

# Server
PORT=8001

# PostgreSQL (arivu's own database)
DATABASE_URL=postgresql+asyncpg://arivu:arivu123@localhost:5432/arivu

# Redis (shared with Whatomate, separate key prefixes)
REDIS_URL=redis://localhost:6379/0

# Whatomate API (the message bridge)
WHATOMATE_BASE_URL=http://localhost:8080
WHATOMATE_API_KEY=your-whatomate-api-key-here
# Get this from Whatomate UI: Settings -> API Keys -> Create Key

# Whatomate webhook secret (to verify incoming webhooks from Whatomate)
WHATOMATE_WEBHOOK_SECRET=your-webhook-secret-here
# This is the "Secret" field when you create the webhook in Whatomate UI

# Meta / WhatsApp Cloud API (for sending Flow messages directly)
META_PHONE_NUMBER_ID=your-phone-number-id
META_ACCESS_TOKEN=your-permanent-access-token
META_API_VERSION=v20.0

# Sarvam AI (for Kannada intent classification and STT)
# TODO: Get API key from https://www.sarvam.ai/
SARVAM_API_KEY=your-sarvam-api-key-here
SARVAM_BASE_URL=https://api.sarvam.ai

# ── Admin Portal — Auth ────────────────────────────────────────────────────
# Generate a strong random secret: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-strong-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Admin Portal — AWS S3 ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=arivu-kendra-media

# ── Admin Portal — Gemini AI ──────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# App
ENVIRONMENT=development
LOG_LEVEL=debug
